# Zenoh settings
# From host, simulator connects to tcp/localhost:7447
# From within docker network, components connect to tcp/zenoh:7447
ZENOH_ENDPOINT=tcp/zenoh:7447
ZENOH_HOST_ENDPOINT=tcp/localhost:7447
ZENOH_KEY_EXPRESSION=/myfactory/machine1/temperature

# Apache IoTDB settings
# From host, connect to localhost:6667
# From within docker network, components connect to host "iotdb"
IOTDB_HOST=iotdb
IOTDB_PORT=6667
IOTDB_USER=root
IOTDB_PASSWORD=root
IOTDB_DATABASE=root.myfactory
IOTDB_DEVICE=root.myfactory.machine1
IOTDB_MEASUREMENT=temperature

# Dashboard settings
DASHBOARD_PORT=8080

# Local simulator settings
SIMULATOR_INTERVAL_SECONDS=1.0
SIMULATOR_MIN_VALUE=15.0
SIMULATOR_MAX_VALUE=35.0
