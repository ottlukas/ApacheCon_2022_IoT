{
  listen: {endpoints: ["tcp/0.0.0.0:7447"]},
  plugins: {
    storage_manager: {
      backends: {
        memory_backend_01: { // Unique name for this backend instance
          kind: "memory"
        }
      },
      volumes: { // Defines how key expressions map to backends
        "myfactory/**": { // Match key expressions starting with myfactory/
          backend: "memory_backend_01",
          // Default behavior is to store PUTs. No extra config needed for that.
        }
      }
    },
    rest: {http_port: 8000}
  },
  // Uncomment to enable shared memory support
  // transport: {
  //   shared_memory: {enabled: true, mode: "lazy"},
  // },
}
